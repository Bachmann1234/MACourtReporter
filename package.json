{
  "name": "macourtreporter",
  "version": "1.0.0",
  "description": "Report on the activities of the MA General Court",
  "dependencies": {
    "@atproto/api": "^0.20.15",
    "better-sqlite3": "^12.10.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "private": true,
  "scripts": {
    "clean": "rm -rf node_modules dist",
    "format": "biome format --write .",
    "build": "tsc; ./copyStaticFiles.sh",
    "test": "vitest run --coverage",
    "ci": "npm run lint && npm run build && npm run test",
    "lint": "biome check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node ./dist/src/db/migrate.js",
    "queryBills": "node ./dist/src/scripts/queryRecentBills.js",
    "updateBills": "node ./dist/src/scripts/updateBillsInDb.js",
    "postBill": "node ./dist/src/scripts/postBill.js",
    "queueStatus": "node ./dist/src/scripts/queueStatus.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bachmann1234/MACourtReporter.git"
  },
  "author": "Matt Bachmann",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Bachmann1234/MACourtReporter/issues"
  },
  "homepage": "https://github.com/Bachmann1234/MACourtReporter#readme",
  "engines": {
    "node": "24.x"
  }
}
